---
import Layout from '../layouts/Layout.astro';

const documents = [
  { name: 'Foundation Blueprint', category: 'Blueprints', originator: 'Tesla', status: 'Approved', project: 'Downtown Office Building', uploadedBy: 'Mike Anderson', date: '18 Jan 2026' },
  { name: 'Building Permit 2026', category: 'Permits', originator: 'Zublin', status: 'Pending', project: 'Riverside Apartments', uploadedBy: 'Sarah Johnson', date: '20 Jan 2026' },
  { name: 'Safety Inspection Report', category: 'Safety', originator: 'Strabag', status: 'Approved', project: 'Downtown Office Building', uploadedBy: 'John Smith', date: '17 Jan 2026' },
  { name: 'Change Order CO-145', category: 'Change Orders', originator: 'Zublin', status: 'Pending', project: 'Riverside Apartments', uploadedBy: 'Mike Anderson', date: '16 Jan 2026' },
  { name: 'Material Submittal - Concrete', category: 'Submittals', originator: 'Goldbeck', status: 'Approved', project: 'Downtown Office Building', uploadedBy: 'Bobby Wong', date: '15 Jan 2026' },
