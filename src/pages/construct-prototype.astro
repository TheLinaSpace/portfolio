      { title: 'RFI-002 – Pile Foundation Depth Clarification', type: 'RFI', status: 'Open', project: 'Central Plaza Tower', submittedBy: 'Tom Jonas', contractor: 'Siemens', date: '15 Jan 2026' },
      { title: 'DCR-015 – Stairwell Width Adjustment', type: 'DCR', status: 'Rejected', project: 'Downtown Office Building', submittedBy: 'Lisa Chen', contractor: 'Max Boegl', date: '14 Jan 2026' },
      { title: 'CR-008 – Facade Material Substitution', type: 'CR', status: 'Pending', project: 'Central Plaza Tower', submittedBy: 'Mike Anderson', contractor: 'Goldbeck', date: '13 Jan 2026' },
      { title: 'WR-024 – Drainage Blockage – North Zone', type: 'WR', status: 'Approved', project: 'Riverside Apartments', submittedBy: 'Sarah Johnson', contractor: 'Strabag', date: '12 Jan 2026' },
    ]}}>
      window.__taskDetails = taskDetails;
      window.__reviewLogs = reviewLogs;
      window.__projectDetails = projectDetails;
      window.__workspaceData = workspaceData;
      window.__allDocuments = allDocuments;
      window.__allRequests = allRequests;
    </script>
    </div> <!-- end ml-56 wrapper -->
  </main>
</Layout>

<script>
  // ===== NAV SWITCHING =====
  const views: Record<string, HTMLElement | null> = {
    tasks: document.getElementById('task-list-view'),
    projects: document.getElementById('project-list-view'),
    requests: document.getElementById('request-list-view'),
    'project-detail': document.getElementById('project-detail-view'),
  };

  const activeNavClass = 'bg-neutral-100 text-neutral-900 font-medium';
  const inactiveNavClass = 'text-neutral-500 hover:bg-neutral-50 hover:text-neutral-900 transition-colors';

  document.querySelectorAll<HTMLAnchorElement>('.nav-item').forEach(item => {
    item.addEventListener('click', (e) => {
      e.preventDefault();
      const target = item.dataset.nav || '';
      if (!views[target]) return;

      // Hide all views
      Object.values(views).forEach(v => v?.classList.add('hidden'));
      // Show target
      views[target]?.classList.remove('hidden');

      // Update nav active states
      document.querySelectorAll<HTMLAnchorElement>('.nav-item').forEach(n => {
        n.className = `nav-item flex items-center gap-3 px-3 py-2 rounded-lg text-sm ${n.dataset.nav === target ? activeNavClass : inactiveNavClass}`;
      });
    });
  });

  // ===== PROJECT FILTERS =====
  const pfilters: Record<string, string> = { type: '', client: '' };

  ['ptype', 'pclient'].forEach(key => {
    const trigger = document.getElementById(`${key}-trigger`);
    const dropdown = document.getElementById(`${key}-dropdown`);
    const wrapper = document.getElementById(`${key}-wrapper`);
    trigger?.addEventListener('click', () => dropdown?.classList.toggle('hidden'));
    document.addEventListener('click', (e) => {
      if (wrapper && !wrapper.contains(e.target as Node)) dropdown?.classList.add('hidden');
    });
  });

  document.querySelectorAll<HTMLButtonElement>('.project-filter-option').forEach(btn => {
    btn.addEventListener('click', () => {
      const key = btn.dataset.pfilter || '';
      const value = btn.dataset.value || '';
      pfilters[key] = value;

      const labelKey = key === 'type' ? 'ptype' : 'pclient';
      const label = document.getElementById(`${labelKey}-label`);
      const trigger = document.getElementById(`${labelKey}-trigger`);
      if (label) {
        label.textContent = value || 'Select';
        trigger?.classList.toggle('text-neutral-400', !value);
        trigger?.classList.toggle('text-neutral-900', !!value);
      }
      document.getElementById(`${labelKey}-dropdown`)?.classList.add('hidden');

      document.querySelectorAll<HTMLTableRowElement>('.project-row').forEach(row => {
        const matchType = !pfilters.type || row.dataset.ptype === pfilters.type;
        const matchClient = !pfilters.client || row.dataset.pclient === pfilters.client;
        row.classList.toggle('hidden', !(matchType && matchClient));
      });
    });
  });

  // ===== REQUEST FILTERS =====
  const rfilters: Record<string, string> = { type: '', project: '' };

  ['rtype', 'rproject'].forEach(key => {
    const trigger = document.getElementById(`${key}-trigger`);
    const dropdown = document.getElementById(`${key}-dropdown`);
    const wrapper = document.getElementById(`${key}-wrapper`);
    trigger?.addEventListener('click', () => dropdown?.classList.toggle('hidden'));
    document.addEventListener('click', (e) => {
      if (wrapper && !wrapper.contains(e.target as Node)) dropdown?.classList.add('hidden');
    });
  });

  document.querySelectorAll<HTMLButtonElement>('.request-filter-option').forEach(btn => {
    btn.addEventListener('click', () => {
      const key = btn.dataset.rfilter || '';
      const value = btn.dataset.value || '';
      rfilters[key] = value;

      const labelKey = key === 'type' ? 'rtype' : 'rproject';
      const label = document.getElementById(`${labelKey}-label`);
      const trigger = document.getElementById(`${labelKey}-trigger`);
      if (label) {
        label.textContent = value || 'Select';
        trigger?.classList.toggle('text-neutral-400', !value);
        trigger?.classList.toggle('text-neutral-900', !!value);
      }
      document.getElementById(`${labelKey}-dropdown`)?.classList.add('hidden');

      document.querySelectorAll<HTMLTableRowElement>('.request-row').forEach(row => {
        const matchType = !rfilters.type || row.dataset.rtype === rfilters.type;
        const matchProject = !rfilters.project || row.dataset.rproject === rfilters.project;
        row.classList.toggle('hidden', !(matchType && matchProject));
      });
    });
  });

  // ===== PROJECT DETAIL VIEW =====
  const projectDetailsData = (window as any).__projectDetails as Record<string, any>;

  const projBadgeColors: Record<string, { bg: string; text: string }> = {
    'Released':    { bg: 'bg-emerald-100', text: 'text-emerald-700' },
    'In Progress': { bg: 'bg-blue-50',     text: 'text-blue-600' },
    'Pending':     { bg: 'bg-orange-50',   text: 'text-orange-500' },
    'On Hold':     { bg: 'bg-neutral-100', text: 'text-neutral-500' },
    'Completed':   { bg: 'bg-emerald-50',  text: 'text-emerald-600' },
  };

  function openProjectDetail(name: string) {
    const d = projectDetailsData[name];
    if (!d) return;

    // Show project detail, hide others
    Object.entries(views).forEach(([k, v]) => v?.classList.toggle('hidden', k !== 'project-detail'));

    // Title
    const titleEl = document.getElementById('proj-title');
    if (titleEl) titleEl.textContent = name;

    // Badge
    const badge = document.getElementById('proj-badge');
    if (badge) {
      const c = projBadgeColors[d.badge] || { bg: 'bg-neutral-100', text: 'text-neutral-600' };
      badge.className = `text-xs font-medium px-2.5 py-0.5 rounded-full ${c.bg} ${c.text}`;
      badge.textContent = d.badge;
    }

    // Meta
    const meta = document.getElementById('proj-meta');
    if (meta) meta.textContent = `Created By: ${d.createdBy} on ${d.date}   ·   Contractor: ${d.contractor}`;

    // General info
    const gi = document.getElementById('proj-general-info');
    if (gi) {
      const fields = [
        { label: 'Area', value: d.area },
        { label: 'Level', value: d.level },
        { label: 'Discipline', value: d.discipline },
        { label: 'Purpose', value: d.purpose },
        { label: 'Category', value: d.category },
      ];
      gi.innerHTML = fields.map(f => `
        <div class="flex items-center justify-between">
          <span class="text-sm text-neutral-400">${f.label}</span>
          <span class="text-sm text-neutral-900">${f.value}</span>
        </div>
      `).join('');
    }

    // Description
    const desc = document.getElementById('proj-description');
    if (desc) desc.textContent = d.description;

    // Activity log
    const log = document.getElementById('proj-activity-log');
    if (log) {
      log.innerHTML = d.activityLog.map((e: any) => `
        <div class="flex items-center gap-6">
          <span class="text-sm text-neutral-400 w-24 shrink-0">${e.date}</span>
          <span class="text-sm text-neutral-900 underline underline-offset-2 cursor-pointer hover:text-neutral-600">${e.action}</span>
        </div>
      `).join('');
    }

    // PO items
    const po = document.getElementById('proj-po-items');
    if (po) {
      po.innerHTML = d.poItems.map((item: any) => `
        <div class="flex items-center justify-between">
          <span class="text-sm text-neutral-500">${item.label}</span>
          <span class="text-sm text-neutral-900">${item.amount}</span>
        </div>
      `).join('');
    }

    // PO total
    const total = document.getElementById('proj-po-total');
    if (total) {
      const sum = d.poItems.reduce((acc: number, item: any) => {
        return acc + parseInt(item.amount.replace(/[^0-9]/g, ''));
      }, 0);
      total.textContent = `${sum.toLocaleString()}$`;
    }

    // Populate documents tab
    const allDocs = (window as any).__allDocuments as any[];
    const projDocs = allDocs.filter((doc: any) => doc.project === name);
    const docsTbody = document.getElementById('proj-docs-tbody');
    const docsEmpty = document.getElementById('proj-docs-empty');
    const docStatusCls: Record<string, string> = { Approved: 'text-emerald-600', Pending: 'text-orange-500', Rejected: 'text-red-500' };
    if (docsTbody) {
      docsTbody.innerHTML = projDocs.map((doc: any) => `
        <tr class="border-b border-neutral-100 hover:bg-neutral-50/50 transition-colors">
          <td class="px-3 py-3.5 text-sm text-neutral-900">${doc.name}</td>
          <td class="px-3 py-3.5 text-sm text-neutral-700">${doc.category}</td>
          <td class="px-3 py-3.5 text-sm text-neutral-700">${doc.originator}</td>
          <td class="px-3 py-3.5"><span class="text-sm font-medium ${docStatusCls[doc.status] || 'text-neutral-600'}">${doc.status}</span></td>
          <td class="px-3 py-3.5 text-sm text-neutral-500">${doc.uploadedBy} on ${doc.date}</td>
          <td class="px-3 py-3.5 text-center"><button class="text-neutral-400 hover:text-neutral-700"><svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/></svg></button></td>
        </tr>
      `).join('');
    }
    if (docsEmpty) docsEmpty.classList.toggle('hidden', projDocs.length > 0);

    // Populate requests tab
    const allReqs = (window as any).__allRequests as any[];
    const projReqs = allReqs.filter((req: any) => req.project === name);
    const reqsTbody = document.getElementById('proj-requests-tbody');
    const reqsEmpty = document.getElementById('proj-requests-empty');
    const reqStatusCls: Record<string, string> = { Open: 'text-blue-600', Pending: 'text-orange-500', Approved: 'text-emerald-600', Rejected: 'text-red-500', 'In Progress': 'text-blue-500' };
    if (reqsTbody) {
      reqsTbody.innerHTML = projReqs.map((req: any) => `
        <tr class="border-b border-neutral-100 hover:bg-neutral-50/50 transition-colors">
          <td class="px-3 py-3.5 text-sm text-neutral-900">${req.title}</td>
          <td class="px-3 py-3.5"><span class="text-xs font-medium px-2 py-0.5 rounded bg-neutral-100 text-neutral-700">${req.type}</span></td>
          <td class="px-3 py-3.5"><span class="text-sm font-medium ${reqStatusCls[req.status] || 'text-neutral-600'}">${req.status}</span></td>
          <td class="px-3 py-3.5 text-sm text-neutral-700">${req.contractor}</td>
          <td class="px-3 py-3.5 text-sm text-neutral-500">${req.submittedBy} on ${req.date}</td>
          <td class="px-3 py-3.5 text-center"><button class="text-neutral-400 hover:text-neutral-700"><svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/></svg></button></td>
        </tr>
      `).join('');
    }
    if (reqsEmpty) reqsEmpty.classList.toggle('hidden', projReqs.length > 0);

    // Reset tabs
    activateProjTab('overview');
  }

  function activateProjTab(tab: string) {
    document.querySelectorAll<HTMLButtonElement>('.proj-tab').forEach(t => {
      const isActive = t.dataset.ptab === tab;
      t.className = `proj-tab text-left px-3 py-2 text-sm ${isActive ? 'font-medium text-neutral-900 border border-neutral-200 rounded-lg bg-white' : 'text-neutral-500 hover:text-neutral-900 transition-colors'}`;
    });

    const panels = ['overview', 'documents', 'requests'];
    panels.forEach(p => {
      document.getElementById(`ptab-${p}`)?.classList.toggle('hidden', p !== tab);
    });
  }

  document.querySelectorAll<HTMLButtonElement>('.proj-tab').forEach(t => {
    t.addEventListener('click', () => activateProjTab(t.dataset.ptab || 'overview'));
  });

  document.querySelectorAll<HTMLButtonElement>('.project-name-link').forEach(btn => {
    btn.addEventListener('click', () => openProjectDetail(btn.dataset.projectName || ''));
  });

  document.getElementById('project-back')?.addEventListener('click', () => {
    Object.values(views).forEach(v => v?.classList.add('hidden'));
    views['projects']?.classList.remove('hidden');
  });

  // ===== WORKSPACE DROPDOWN =====
  const workspaceTrigger = document.getElementById('workspace-trigger');
  const workspaceDropdown = document.getElementById('workspace-dropdown');
  const workspaceWrapper = document.getElementById('workspace-wrapper');
  const allWorkspaceData = (window as any).__workspaceData as Record<string, { tasks: any[]; projects: any[] }>;

  const taskStatusClasses: Record<string, string> = {
    'In Progress': 'text-blue-600',
    'Pending': 'text-orange-500',
    'Completed': 'text-emerald-600',
    'Blocked': 'text-red-500',
  };

  const projStatusClasses: Record<string, string> = {
    'In Progress': 'text-blue-600',
    'Pending': 'text-orange-500',
    'Completed': 'text-emerald-600',
    'On Hold': 'text-neutral-400',
  };

  const dotsMenu = `<button class="text-neutral-400 hover:text-neutral-700 transition-colors"><svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/></svg></button>`;

  function renderTasks(taskList: any[]) {
    const tbody = document.getElementById('task-tbody');
    if (!tbody) return;
    tbody.innerHTML = taskList.map(t => `
      <tr class="task-row border-b border-neutral-100 hover:bg-neutral-50/50 transition-colors" data-discipline="${t.discipline}" data-contractor="${t.contractor}" data-project="${t.project}">
        <td class="px-3 py-3.5"><input type="checkbox" class="task-cb w-4 h-4 rounded border-neutral-300 accent-neutral-900 cursor-pointer"></td>
        <td class="px-3 py-3.5 text-sm text-neutral-900"><button class="task-name-link hover:underline underline-offset-2 text-left" data-task-name="${t.name}" data-task-type="Document Review">${t.name}</button></td>
        <td class="px-3 py-3.5 text-sm text-neutral-700">${t.project}</td>
        <td class="px-3 py-3.5 text-sm text-neutral-700">${t.discipline}</td>
        <td class="px-3 py-3.5 text-sm text-neutral-700">${t.contractor}</td>
        <td class="px-3 py-3.5 text-sm text-neutral-700">${t.priority}</td>
        <td class="px-3 py-3.5"><span class="text-sm font-medium ${taskStatusClasses[t.status] || 'text-neutral-600'}">${t.status}</span></td>
        <td class="px-3 py-3.5 text-sm text-neutral-500">${t.assignedTo} on ${t.date}</td>
        <td class="px-3 py-3.5 text-center">${dotsMenu}</td>
      </tr>
    `).join('');
    attachTaskListeners();
  }

  function renderProjects(projectList: any[]) {
    const tbody = document.getElementById('project-tbody');
    if (!tbody) return;
    tbody.innerHTML = projectList.map(p => `
      <tr class="project-row border-b border-neutral-100 hover:bg-neutral-50/50 transition-colors" data-ptype="${p.type}" data-pclient="${p.client}">
        <td class="px-3 py-3.5"><input type="checkbox" class="w-4 h-4 rounded border-neutral-300 accent-neutral-900 cursor-pointer"></td>
        <td class="px-3 py-3.5 text-sm text-neutral-900 font-medium"><button class="project-name-link hover:underline underline-offset-2 text-left" data-project-name="${p.name}">${p.name}</button></td>
        <td class="px-3 py-3.5 text-sm text-neutral-700">${p.type}</td>
        <td class="px-3 py-3.5 text-sm text-neutral-700">${p.client}</td>
        <td class="px-3 py-3.5 text-sm text-neutral-700">${p.location}</td>
        <td class="px-3 py-3.5"><span class="text-sm font-medium ${projStatusClasses[p.status] || 'text-neutral-600'}">${p.status}</span></td>
        <td class="px-3 py-3.5 text-sm text-neutral-500">${p.manager}</td>
        <td class="px-3 py-3.5 text-sm text-neutral-500">${p.start}</td>
        <td class="px-3 py-3.5 text-center">${dotsMenu}</td>
      </tr>
    `).join('');
    attachProjectListeners();
  }

  function attachTaskListeners() {
    document.querySelectorAll<HTMLButtonElement>('.task-name-link').forEach(link => {
      link.addEventListener('click', () => openTaskDetail(link.dataset.taskName || ''));
    });
    const selectAll = document.getElementById('select-all') as HTMLInputElement | null;
    document.querySelectorAll<HTMLInputElement>('.task-cb').forEach(cb => {
      cb.addEventListener('change', () => {
        if (selectAll) {
          const visible = Array.from(document.querySelectorAll<HTMLInputElement>('.task-cb')).filter(c => !c.closest('.task-row')?.classList.contains('hidden'));
          selectAll.checked = visible.length > 0 && visible.every(c => c.checked);
        }
      });
    });
  }

  function attachProjectListeners() {
    document.querySelectorAll<HTMLButtonElement>('.project-name-link').forEach(btn => {
      btn.addEventListener('click', () => openProjectDetail(btn.dataset.projectName || ''));
    });
  }

  workspaceTrigger?.addEventListener('click', () => workspaceDropdown?.classList.toggle('hidden'));

  document.addEventListener('click', (e) => {
    if (workspaceWrapper && !workspaceWrapper.contains(e.target as Node)) {
      workspaceDropdown?.classList.add('hidden');
    }
  });

  document.querySelectorAll<HTMLButtonElement>('.workspace-option').forEach(btn => {
    btn.addEventListener('click', () => {
      const label = btn.textContent?.trim() || '';
      const triggerLabel = workspaceTrigger?.querySelector('span.truncate');
      const triggerDot = workspaceTrigger?.querySelector('span.rounded-full');
      if (triggerLabel) triggerLabel.textContent = label;
      if (triggerDot) {
        triggerDot.className = `w-2 h-2 rounded-full shrink-0 ${label === 'Building Z' ? 'bg-emerald-500' : 'bg-neutral-400'}`;
      }
      workspaceDropdown?.classList.add('hidden');

      const data = allWorkspaceData[label];
      if (data) {
        renderTasks(data.tasks);
        renderProjects(data.projects);
      }
    });
  });

  // ===== DROPDOWN FILTERS =====
  const filters: Record<string, string> = { discipline: '', contractor: '', project: '' };

  ['discipline', 'contractor', 'project'].forEach(key => {
    const trigger = document.getElementById(`${key}-trigger`);
    const dropdown = document.getElementById(`${key}-dropdown`);
    const wrapper = document.getElementById(`${key}-wrapper`);

    trigger?.addEventListener('click', () => dropdown?.classList.toggle('hidden'));

    document.addEventListener('click', (e) => {
      if (wrapper && !wrapper.contains(e.target as Node)) {
        dropdown?.classList.add('hidden');
      }
    });
  });

  document.querySelectorAll<HTMLButtonElement>('.filter-option').forEach(btn => {
    btn.addEventListener('click', () => {
      const key = btn.dataset.filter || '';
      const value = btn.dataset.value || '';
      filters[key] = value;

      const label = document.getElementById(`${key}-label`);
      const trigger = document.getElementById(`${key}-trigger`);
      if (label) {
        label.textContent = value || 'Select';
        trigger?.classList.toggle('text-neutral-400', !value);
        trigger?.classList.toggle('text-neutral-900', !!value);
      }

      document.getElementById(`${key}-dropdown`)?.classList.add('hidden');
      filterRows();
    });
  });

  function filterRows() {
    document.querySelectorAll<HTMLTableRowElement>('.task-row').forEach(row => {
      const matchDiscipline = !filters.discipline || row.dataset.discipline === filters.discipline;
      const matchContractor = !filters.contractor || row.dataset.contractor === filters.contractor;
      const matchProject = !filters.project || row.dataset.project === filters.project;
      row.classList.toggle('hidden', !(matchDiscipline && matchContractor && matchProject));
    });
  }

  // ===== SELECT ALL CHECKBOX =====
  const selectAll = document.getElementById('select-all') as HTMLInputElement | null;
  const taskCbs = document.querySelectorAll<HTMLInputElement>('.task-cb');

  selectAll?.addEventListener('change', () => {
    taskCbs.forEach(cb => {
      const row = cb.closest('.task-row');
      if (row && !row.classList.contains('hidden')) {
        cb.checked = selectAll.checked;
      }
    });
  });

  taskCbs.forEach(cb => {
    cb.addEventListener('change', () => {
      if (selectAll) {
        const visibleCbs = Array.from(taskCbs).filter(c => !c.closest('.task-row')?.classList.contains('hidden'));
        selectAll.checked = visibleCbs.length > 0 && visibleCbs.every(c => c.checked);
      }
    });
  });

  // ===== TASK DETAIL VIEW =====
  const listView = document.getElementById('task-list-view');
  const detailView = document.getElementById('task-detail-view');
  const taskDetails = (window as any).__taskDetails as Record<string, any>;
  let currentTaskName = '';

  const statusBadgeColors: Record<string, { bg: string; text: string }> = {
    'In Progress': { bg: 'bg-blue-50', text: 'text-blue-600' },
    'Completed':   { bg: 'bg-emerald-50', text: 'text-emerald-600' },
    'Pending':     { bg: 'bg-orange-50', text: 'text-orange-500' },
    'Blocked':     { bg: 'bg-red-50', text: 'text-red-500' },
  };

  function openTaskDetail(taskName: string) {
    const detail = taskDetails[taskName];
    if (!detail) return;

    currentTaskName = taskName;

    listView?.classList.add('hidden');
    detailView?.classList.remove('hidden');

    const titleEl = document.getElementById('detail-task-title');
    if (titleEl) titleEl.textContent = taskName;

    const badge = document.getElementById('detail-status-badge');
    if (badge) {
      const colors = statusBadgeColors[detail.status] || { bg: 'bg-neutral-100', text: 'text-neutral-600' };
      badge.className = `text-xs font-medium px-2 py-0.5 rounded-full ${colors.bg} ${colors.text}`;
      badge.textContent = detail.status;
    }

    const assignInfo = document.getElementById('detail-assign-info');
    if (assignInfo) assignInfo.textContent = `Assigned to ${detail.assignedTo} on ${detail.date}`;

    renderRevisions(detail.revisions);
    renderMetadata(detail);
    renderAttachments(detail.attachments);
    activateTab('general');
  }

  function renderRevisions(count: number) {
    const container = document.getElementById('detail-revisions');
    if (!container) return;
    container.innerHTML = '';

    for (let i = 1; i <= count; i++) {
      const isActive = i === count;
      const btn = document.createElement('button');
      btn.className = `revision-btn flex items-center gap-2 w-full px-3 py-2 rounded-lg text-sm transition-colors ${isActive ? 'bg-neutral-100 font-medium text-neutral-900' : 'text-neutral-600 hover:bg-neutral-50'}`;
      btn.dataset.rev = String(i);
      btn.innerHTML = `
        <span class="w-2 h-2 rounded-full shrink-0 ${isActive ? 'bg-emerald-500' : 'bg-neutral-300'}"></span>
        Rev ${i}
      `;
      btn.addEventListener('click', () => {
        container.querySelectorAll('.revision-btn').forEach(b => {
          b.className = 'revision-btn flex items-center gap-2 w-full px-3 py-2 rounded-lg text-sm transition-colors text-neutral-600 hover:bg-neutral-50';
          b.querySelector('span')!.className = 'w-2 h-2 rounded-full shrink-0 bg-neutral-300';
        });
        btn.className = 'revision-btn flex items-center gap-2 w-full px-3 py-2 rounded-lg text-sm transition-colors bg-neutral-100 font-medium text-neutral-900';
        btn.querySelector('span')!.className = 'w-2 h-2 rounded-full shrink-0 bg-emerald-500';
      });
      container.appendChild(btn);
    }
  }

  function renderMetadata(detail: any) {
    const list = document.getElementById('metadata-list');
    if (!list) return;

    const fields = [
      { label: 'Location', value: detail.location },
      { label: 'Level', value: detail.level },
      { label: 'Discipline', value: detail.discipline },
      { label: 'Priority', value: detail.priority },
      { label: 'Type', value: detail.type },
    ];

    list.innerHTML = fields.map(f => `
      <div class="flex items-center justify-between">
        <span class="text-sm text-neutral-500">${f.label}</span>
        <span class="text-sm text-neutral-900 font-medium">${f.value}</span>
      </div>
    `).join('');
  }

  function renderAttachments(attachments: { date: string; type: string }[]) {
    const list = document.getElementById('attachments-list');
    if (!list) return;

    list.innerHTML = attachments.map(a => `
      <div class="flex items-center justify-between py-1.5">
        <span class="text-sm text-neutral-500">${a.date}</span>
        <span class="text-xs font-medium px-2 py-0.5 rounded bg-neutral-100 text-neutral-700">${a.type}</span>
      </div>
    `).join('');
  }

  function activateTab(tab: string) {
    document.querySelectorAll<HTMLButtonElement>('.detail-tab').forEach(t => {
      const isActive = t.dataset.tab === tab;
      t.className = `detail-tab text-sm pb-2 ${isActive ? 'font-medium text-neutral-900 border-b-2 border-neutral-900' : 'text-neutral-500 hover:text-neutral-700'}`;
    });

    const general = document.getElementById('tab-general');
    if (general) general.classList.toggle('hidden', tab !== 'general');
  }

  document.querySelectorAll<HTMLButtonElement>('.detail-tab').forEach(t => {
    t.addEventListener('click', () => activateTab(t.dataset.tab || 'general'));
  });

  document.querySelectorAll<HTMLButtonElement>('.task-name-link').forEach(link => {
    link.addEventListener('click', () => {
      openTaskDetail(link.dataset.taskName || '');
    });
  });

  document.getElementById('task-back')?.addEventListener('click', () => {
    detailView?.classList.add('hidden');
    listView?.classList.remove('hidden');
  });

  // ===== REVIEW LOG SIDE SHEET =====
  const reviewLogs = (window as any).__reviewLogs as Record<string, any[]>;
  const reviewSheet = document.getElementById('review-sheet');
  const reviewBackdrop = document.getElementById('review-backdrop');

  function openReviewSheet() {
    const entries = reviewLogs[currentTaskName] || [];

    const approved = entries.filter((e: any) => e.status === 'Approved').length;
    const declined = entries.filter((e: any) => e.status === 'Declined').length;
    const pending = entries.filter((e: any) => e.status === 'Pending').length;

    const countApproved = document.querySelector('#review-count-approved span:nth-child(2)');
    const countDeclined = document.querySelector('#review-count-declined span:nth-child(2)');
    const countPending = document.querySelector('#review-count-pending span:nth-child(2)');
    if (countApproved) countApproved.textContent = String(approved);
    if (countDeclined) countDeclined.textContent = String(declined);
    if (countPending) countPending.textContent = String(pending);

    const list = document.getElementById('review-list');
    if (list) {
      const statusConfig: Record<string, { dot: string; badge: string; badgeBg: string }> = {
        Approved: { dot: 'bg-emerald-500', badge: 'text-emerald-700', badgeBg: 'bg-emerald-50' },
        Declined: { dot: 'bg-red-500', badge: 'text-red-700', badgeBg: 'bg-red-50' },
        Pending:  { dot: 'bg-orange-400', badge: 'text-orange-700', badgeBg: 'bg-orange-50' },
      };

      list.innerHTML = entries.map((e: any) => {
        const cfg = statusConfig[e.status] || statusConfig.Pending;
        const initials = e.name.split(' ').map((w: string) => w[0]).join('');
        const colors = ['bg-violet-100 text-violet-700', 'bg-blue-100 text-blue-700', 'bg-amber-100 text-amber-700', 'bg-rose-100 text-rose-700', 'bg-teal-100 text-teal-700'];
        const color = colors[e.name.length % colors.length];
        return `
          <div class="flex gap-3 py-4 border-b border-neutral-100 last:border-0">
            <div class="w-9 h-9 rounded-full ${color} flex items-center justify-center text-xs font-semibold shrink-0">${initials}</div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center justify-between mb-0.5">
                <span class="text-sm font-medium text-neutral-900">${e.name}</span>
                <span class="text-xs font-medium px-2 py-0.5 rounded-full ${cfg.badgeBg} ${cfg.badge}">${e.status}</span>
              </div>
              <p class="text-xs text-neutral-500 mb-1">${e.role} &middot; ${e.date}</p>
              ${e.comment ? `<p class="text-sm text-neutral-600 mt-1.5">${e.comment}</p>` : ''}
            </div>
          </div>
        `;
      }).join('');
    }

    reviewBackdrop?.classList.remove('hidden');
    requestAnimationFrame(() => {
      reviewSheet?.classList.remove('translate-x-full');
    });
  }

  function closeReviewSheet() {
    reviewSheet?.classList.add('translate-x-full');
    reviewBackdrop?.classList.add('hidden');
  }

  document.getElementById('review-log-btn')?.addEventListener('click', openReviewSheet);
  document.getElementById('review-close')?.addEventListener('click', closeReviewSheet);
  reviewBackdrop?.addEventListener('click', closeReviewSheet);
</script>
