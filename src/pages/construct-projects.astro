  { name: 'East Wing Renovation', client: 'Goldbeck', location: 'East District', manager: 'John Smith', status: 'Ready for Handover', type: 'Renovation', start: '10 Nov 2025' },
  { name: 'Harbour Bridge Overpass', client: 'Strabag', location: 'Harbour', manager: 'Tom Jonas', status: 'Completed', type: 'Infrastructure', start: '01 Jan 2024' },
  { name: 'Central Plaza Tower', client: 'Siemens', location: 'City Centre', manager: 'Sarah Johnson', status: 'In Construction', type: 'Commercial', start: '20 Sep 2025' },
  { name: 'Green Valley Residences', client: 'Goldbeck', location: 'Valley Road', manager: 'Lisa Chen', status: 'In Design', type: 'Residential', start: '01 Apr 2026' },
  { name: 'Industrial Park – Phase 2', client: 'Max Boegl', location: 'South Zone', manager: 'Mike Anderson', status: 'Completed', type: 'Industrial', start: '05 Mar 2024' },
