const projectTypes = [...new Set(projects.map(p => p.type))];
const projectClients = [...new Set(projects.map(p => p.client))];

const allDocuments = [
  { name: 'Foundation Blueprint Rev A', project: 'Downtown Office Building', type: 'Drawing', discipline: 'Structural', status: 'Approved', issuedBy: 'Sarah Johnson', date: '20 Jan 2026' },
  { name: 'MEP Coordination Drawing', project: 'Downtown Office Building', type: 'Drawing', discipline: 'MEP', status: 'Under Review', issuedBy: 'Mike Anderson', date: '15 Jan 2026' },
  { name: 'Facade Specification', project: 'Downtown Office Building', type: 'Specification', discipline: 'Architecture', status: 'Approved', issuedBy: 'Sarah Johnson', date: '10 Jan 2026' },
  { name: 'Structural Calculation Report', project: 'Riverside Apartments', type: 'Report', discipline: 'Structural', status: 'Approved', issuedBy: 'Mike Anderson', date: '14 Jan 2026' },
  { name: 'Floor Plan – Level 1', project: 'Riverside Apartments', type: 'Drawing', discipline: 'Architecture', status: 'Approved', issuedBy: 'Lisa Chen', date: '12 Jan 2026' },
  { name: 'Warehouse Layout Plan', project: 'North Warehouse Expansion', type: 'Drawing', discipline: 'Civil', status: 'Pending', issuedBy: 'Bobby Wong', date: '01 Feb 2026' },
  { name: 'Fire Suppression Design', project: 'North Warehouse Expansion', type: 'Drawing', discipline: 'MEP', status: 'Pending', issuedBy: 'Bobby Wong', date: '28 Jan 2026' },
  { name: 'Strip-Out Scope Document', project: 'East Wing Renovation', type: 'Specification', discipline: 'Architecture', status: 'Under Review', issuedBy: 'John Smith', date: '05 Jan 2026' },
  { name: 'Structural Strengthening Drawings', project: 'East Wing Renovation', type: 'Drawing', discipline: 'Structural', status: 'On Hold', issuedBy: 'John Smith', date: '20 Dec 2025' },
  { name: 'Overpass As-Built Drawing', project: 'Harbour Bridge Overpass', type: 'Drawing', discipline: 'Civil', status: 'Released', issuedBy: 'Tom Jonas', date: '15 Dec 2024' },
  { name: 'Handover Certificate', project: 'Harbour Bridge Overpass', type: 'Report', discipline: 'Civil', status: 'Released', issuedBy: 'Tom Jonas', date: '15 Dec 2024' },
  { name: 'Tower Foundation Drawing', project: 'Central Plaza Tower', type: 'Drawing', discipline: 'Structural', status: 'Approved', issuedBy: 'Sarah Johnson', date: '10 Jan 2026' },
  { name: 'Steel Frame Design – L1 to L4', project: 'Central Plaza Tower', type: 'Drawing', discipline: 'Structural', status: 'Under Review', issuedBy: 'Sarah Johnson', date: '18 Jan 2026' },
  { name: 'Planning Permit Application', project: 'Green Valley Residences', type: 'Report', discipline: 'Architecture', status: 'Pending', issuedBy: 'Lisa Chen', date: '25 Mar 2026' },
  { name: 'Phase 2 As-Built Package', project: 'Industrial Park – Phase 2', type: 'Drawing', discipline: 'Civil', status: 'Released', issuedBy: 'Mike Anderson', date: '10 Nov 2024' },
];

const allRequests = [
  { title: 'RFI #001 – Foundation Depth Query', project: 'Downtown Office Building', type: 'RFI', status: 'Open', contractor: 'Siemens', submittedBy: 'Sarah Johnson', date: '18 Jan 2026' },
  { title: 'CR #002 – Facade Material Change', project: 'Downtown Office Building', type: 'CR', status: 'Approved', contractor: 'Siemens', submittedBy: 'Sarah Johnson', date: '10 Jan 2026' },
  { title: 'DCR #003 – MEP Routing Revision', project: 'Downtown Office Building', type: 'DCR', status: 'Under Review', contractor: 'Siemens', submittedBy: 'Mike Anderson', date: '05 Jan 2026' },
  { title: 'RFI #004 – Slab Thickness Clarification', project: 'Riverside Apartments', type: 'RFI', status: 'Closed', contractor: 'Zublin', submittedBy: 'Mike Anderson', date: '16 Jan 2026' },
  { title: 'WR #005 – Additional Parking Level', project: 'Riverside Apartments', type: 'WR', status: 'Pending', contractor: 'Zublin', submittedBy: 'Lisa Chen', date: '12 Jan 2026' },
  { title: 'RFI #006 – Steel Grade Clarification', project: 'North Warehouse Expansion', type: 'RFI', status: 'Open', contractor: 'Max Boegl', submittedBy: 'Bobby Wong', date: '01 Feb 2026' },
  { title: 'DCR #007 – Scope Revision East Wing', project: 'East Wing Renovation', type: 'DCR', status: 'Under Review', contractor: 'Goldbeck', submittedBy: 'John Smith', date: '05 Jan 2026' },
  { title: 'RFI #008 – Lighting Spec Query', project: 'Harbour Bridge Overpass', type: 'RFI', status: 'Closed', contractor: 'Strabag', submittedBy: 'Tom Jonas', date: '01 Nov 2024' },
  { title: 'CR #009 – Tower Core Wall Thickness', project: 'Central Plaza Tower', type: 'CR', status: 'Approved', contractor: 'Siemens', submittedBy: 'Sarah Johnson', date: '12 Jan 2026' },
  { title: 'RFI #010 – Planning Requirement Query', project: 'Green Valley Residences', type: 'RFI', status: 'Open', contractor: 'Goldbeck', submittedBy: 'Lisa Chen', date: '28 Mar 2026' },
  { title: 'WR #011 – Road Access Extension', project: 'Industrial Park – Phase 2', type: 'WR', status: 'Closed', contractor: 'Max Boegl', submittedBy: 'Mike Anderson', date: '05 Oct 2024' },
