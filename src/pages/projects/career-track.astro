---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Career Track - Lina">

<main class="max-w-2xl mx-auto px-6 py-12">

    <!-- Back -->
    <a href="/" class="inline-flex items-center gap-2 text-sm text-neutral-700 hover:text-neutral-900 transition-colors mb-10">
      ← Back
    </a>

    <!-- Header -->
    <header class="mb-10">
      <div class="flex items-start justify-between gap-4 mb-2">
        <h1 class="font-semibold text-neutral-900" style="font-size: 32px;">Career Track</h1>
        <div class="flex items-center gap-3 shrink-0 mt-1">
          <a href="https://linacharara.com/dashboard" target="_blank" rel="noopener noreferrer" class="visit-btn inline-flex items-center gap-1.5 text-sm text-neutral-700 border border-neutral-300 rounded px-3 py-1 transition-colors">
            View Prototype →
          </a>
        </div>
      </div>
      <p class="text-xs text-neutral-500 italic mb-8">Real product modified for confidentiality using Figma's design system.</p>
      <p class="text-neutral-700 leading-relaxed">
        Career Track enables administrators, managers, and trainers to monitor team progress, define skill-development areas, and assign tasks based on qualifications.
      </p>
      <div class="flex flex-wrap gap-2 mt-3">
        <span class="inline-flex items-center gap-1.5 text-xs text-neutral-600 border border-neutral-300 rounded-full px-3 py-1">
          <svg width="12" height="12" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M15.852 8.981h-4.588V0h4.588c2.476 0 4.49 2.014 4.49 4.49s-2.014 4.491-4.49 4.491zM12.735 7.51h3.117c1.665 0 3.019-1.355 3.019-3.019s-1.355-3.019-3.019-3.019h-3.117V7.51zm0 1.471H8.148c-2.476 0-4.49-2.014-4.49-4.49S5.672 0 8.148 0h4.588v8.981zm-4.587-7.51c-1.665 0-3.019 1.355-3.019 3.019s1.354 3.02 3.019 3.02h3.117V1.471H8.148zm4.587 15.019H8.148c-2.476 0-4.49-2.014-4.49-4.49s2.014-4.49 4.49-4.49h4.588v8.98zM8.148 8.981c-1.665 0-3.019 1.355-3.019 3.019s1.355 3.019 3.019 3.019h3.117V8.981H8.148zM8.172 24c-2.489 0-4.515-2.014-4.515-4.49s2.014-4.49 4.49-4.49h4.588v4.441c0 2.503-2.047 4.539-4.563 4.539zm-.024-7.51a3.023 3.023 0 0 0-3.019 3.019c0 1.665 1.365 3.019 3.044 3.019 1.705 0 3.093-1.376 3.093-3.068v-2.97H8.148zm7.704 0h-.098c-2.476 0-4.49-2.014-4.49-4.49s2.014-4.49 4.49-4.49h.098c2.476 0 4.49 2.014 4.49 4.49s-2.014 4.49-4.49 4.49zm-.097-7.509c-1.665 0-3.019 1.355-3.019 3.019s1.355 3.019 3.019 3.019h.098c1.665 0 3.019-1.355 3.019-3.019s-1.355-3.019-3.019-3.019h-.098z" fill="#F24E1E"/>
          </svg>
          Figma
        </span>
        <span class="inline-flex items-center gap-1.5 text-xs text-neutral-600 border border-neutral-300 rounded-full px-3 py-1">
          <svg width="12" height="12" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="m4.7144 15.9555 4.7174-2.6471.079-.2307-.079-.1275h-.2307l-.7893-.0486-2.6956-.0729-2.3375-.0971-2.2646-.1214-.5707-.1215-.5343-.7042.0546-.3522.4797-.3218.686.0608 1.5179.1032 2.2767.1578 1.6514.0972 2.4468.255h.3886l.0546-.1579-.1336-.0971-.1032-.0972L6.973 9.8356l-2.55-1.6879-1.3356-.9714-.7225-.4918-.3643-.4614-.1578-1.0078.6557-.7225.8803.0607.2246.0607.8925.686 1.9064 1.4754 2.4893 1.8336.3643.3035.1457-.1032.0182-.0728-.164-.2733-1.3539-2.4467-1.445-2.4893-.6435-1.032-.17-.6194c-.0607-.255-.1032-.4674-.1032-.7285L6.287.1335 6.6997 0l.9957.1336.419.3642.6192 1.4147 1.0018 2.2282 1.5543 3.0296.4553.8985.2429.8318.091.255h.1579v-.1457l.1275-1.706.2368-2.0947.2307-2.6957.0789-.7589.3764-.9107.7468-.4918.5828.2793.4797.686-.0668.4433-.2853 1.8517-.5586 2.9021-.3643 1.9429h.2125l.2429-.2429.9835-1.3053 1.6514-2.0643.7286-.8196.85-.9046.5464-.4311h1.0321l.759 1.1293-.34 1.1657-1.0625 1.3478-.8804 1.1414-1.2628 1.7-.7893 1.36.0729.1093.1882-.0183 2.8535-.607 1.5421-.2794 1.8396-.3157.8318.3886.091.3946-.3278.8075-1.967.4857-2.3072.4614-3.4364.8136-.0425.0304.0486.0607 1.5482.1457.6618.0364h1.621l3.0175.2247.7892.522.4736.6376-.079.4857-1.2142.6193-1.6393-.3886-3.825-.9107-1.3113-.3279h-.1822v.1093l1.0929 1.0686 2.0035 1.8092 2.5075 2.3314.1275.5768-.3218.4554-.34-.0486-2.2039-1.6575-.85-.7468-1.9246-1.621h-.1275v.17l.4432.6496 2.3436 3.5214.1214 1.0807-.17.3521-.6071.2125-.6679-.1214-1.3721-1.9246L14.38 17.959l-1.1414-1.9428-.1397.079-.674 7.2552-.3156.3703-.7286.2793-.6071-.4614-.3218-.7468.3218-1.4753.3886-1.9246.3157-1.53.2853-1.9004.17-.6314-.0121-.0425-.1397.0182-1.4328 1.9672-2.1796 2.9446-1.7243 1.8456-.4128.164-.7164-.3704.0667-.6618.4008-.5889 2.386-3.0357 1.4389-1.882.929-1.0868-.0062-.1579h-.0546l-6.3385 4.1164-1.1293.1457-.4857-.4554.0608-.7467.2307-.2429 1.9064-1.3114Z" fill="#D97757"/>
          </svg>
          Claude
        </span>
        <span class="inline-flex items-center gap-1.5 text-xs text-neutral-600 border border-neutral-300 rounded-full px-3 py-1">
          <svg width="12" height="12" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M.113 10.27A13.026 13.026 0 000 11.48h18.23c-.064-.125-.15-.237-.235-.347-3.117-4.027-4.793-3.677-7.19-3.78-.8-.034-1.34-.048-4.524-.048-1.704 0-3.555.005-5.358.01-.234.63-.459 1.24-.567 1.737h9.342v1.216H.113v.002zm18.26 2.426H.009c.02.326.05.645.094.961h16.955c.754 0 1.179-.429 1.315-.96zm-17.318 4.28s2.81 6.902 10.93 7.024c4.855 0 9.027-2.883 10.92-7.024H1.056zM11.988 0C7.5 0 3.593 2.466 1.531 6.108l4.75-.005v-.002c3.71 0 3.849.016 4.573.047l.448.016c1.563.052 3.485.22 4.996 1.364.82.621 2.007 1.99 2.712 2.965.654.902.842 1.94.396 2.934-.408.914-1.289 1.458-2.353 1.458H.391s.099.42.249.886h22.748A12.026 12.026 0 0024 12.005C24 5.377 18.621 0 11.988 0z" fill="#0B0D0E"/>
          </svg>
          Railway
        </span>
      </div>
    </header>

    <!-- Meta -->
    <dl class="flex flex-col gap-4 text-sm">
      <div>
        <dt class="text-xs text-neutral-500 mb-1">Role</dt>
        <dd class="text-neutral-900">UX/UI Designer (Lead)</dd>
      </div>
      <div>
        <dt class="text-xs text-neutral-500 mb-1">Timeline</dt>
        <dd class="text-neutral-900">Nov 2024 — Ongoing</dd>
      </div>
      <div>
        <dt class="text-xs text-neutral-500 mb-1">Team</dt>
        <dd class="text-neutral-900">Product Manager, Developers, Lead Designer</dd>
      </div>
    </dl>

    <div class="mt-10"></div>

<!-- User Problems -->
    <section class="mb-10">
      <h2 class="font-semibold text-neutral-900 mb-4" style="font-size: 20px;">User Problems</h2>
      <div class="flex flex-col gap-5">
        <div>
          <p class="text-xs text-neutral-500 mb-1.5">Employee</p>
          <p class="text-neutral-700 text-sm leading-7">Lack of clarity regarding required skills for career advancement and role elevation.</p>
        </div>
        <div>
          <p class="text-xs text-neutral-500 mb-1.5">Manager</p>
          <p class="text-neutral-700 text-sm leading-7">Absence of unified documentation tracking employee skill progression and career development guidance.</p>
        </div>
      </div>
    </section>

    <!-- Design Strategy -->
    <section class="mb-10">
      <h2 class="font-semibold text-neutral-900 mb-3" style="font-size: 20px;">Design Strategy</h2>
      <p class="text-neutral-700 text-sm leading-7 mb-6">
        There is never a strict design process to follow. The design strategy would change and adapt depending on the project scope, user problem, business requirements, and the team.
      </p>
      <img src="/career-track/process.jpg" alt="Design process" class="w-full" />
    </section>

    <!-- Product Background -->
    <section class="mb-10">
      <h2 class="font-semibold text-neutral-900 mb-3" style="font-size: 20px;">Product Background</h2>
      <p class="text-neutral-700 text-sm leading-7 mb-5">
        Career Track enables administrators, managers, and trainers to monitor team progress, define skill-development areas, and assign tasks based on qualifications. Employees gain visibility into assigned skills and advancement pathways.
      </p>
      <ul class="list-disc list-inside text-neutral-700 text-sm flex flex-col gap-1 mb-6">
        <li>Skill Module</li>
        <li>Assignment Module</li>
        <li>Dashboard</li>
      </ul>
      <img src="/career-track/site-map.jpg" alt="Site map" class="w-full" />
    </section>

    <!-- Design Evolution -->
    <section class="mb-10">
      <h2 class="font-semibold text-neutral-900 mb-5" style="font-size: 20px;">Design Evolution</h2>

      <!-- Skill Module -->
      <div class="mb-8">
        <h3 class="text-sm font-medium text-neutral-900 mb-2">Skill Module</h3>
        <p class="text-neutral-700 text-sm leading-7 mb-5">Encompasses Skill List, Skill Creation, and Skill Pages. Admins and skill creators establish competencies requested by management teams.</p>
        <img src="/career-track/skill-list.jpg" alt="Skill list" class="w-full mb-4" />
        <img src="/career-track/explanations-skills.png" alt="Skills explanation" class="w-full mb-4" />
        <img src="/career-track/skill-page.jpg" alt="Skill page creation" class="w-full" />
      </div>

      <!-- Assignment Module -->
      <div class="mb-8">
        <h3 class="text-sm font-medium text-neutral-900 mb-2">Assignment Module</h3>
        <p class="text-neutral-700 text-sm leading-7 mb-5">The setup interface for the dashboard experience where skill sets combining roles and skills are established for teams or role groups.</p>
        <img src="/career-track/assignment-page.jpg" alt="Assignment page" class="w-full mb-4" />
        <img src="/career-track/in-between-1.jpg" alt="Assignment module evolution" class="w-full mb-4" />
        <video src="/career-track/Assignment.mp4" autoplay loop muted playsinline class="w-full"></video>
      </div>

      <!-- Dashboard -->
      <div class="mb-8">
        <h3 class="text-sm font-medium text-neutral-900 mb-2">Dashboard</h3>
        <p class="text-neutral-700 text-sm leading-7 mb-5">The most-used module accessible to admins, managers, and trainers. Functions as employee qualification documentation enabling manager task assignment based on demonstrated competencies. Designs evolved through user testing and real-world usage patterns.</p>
        <img src="/career-track/in-between-3.jpg" alt="Dashboard final" class="w-full mb-4" />
        <img src="/career-track/dash-1.jpg" alt="Dashboard" class="w-full mb-4" />
        <img src="/career-track/in-between-4.jpg" alt="Dashboard evolution" class="w-full mb-4" />
        <img src="/career-track/dash-2.png" alt="Dashboard refined" class="w-full mb-4" />
        <img src="/career-track/in-between-5.jpg" alt="Dashboard iteration" class="w-full mb-4" />
        <video src="/career-track/Dashb.mp4" autoplay loop muted playsinline class="w-full"></video>
      </div>
    </section>

    <!-- Design System -->
    <section class="mb-10">
      <h2 class="font-semibold text-neutral-900 mb-3" style="font-size: 20px;">Design System</h2>
      <p class="text-neutral-700 text-sm leading-7 mb-5">
        Utilises Figma's Simple System with custom additions including chips, data tables, and sheets to maintain design consistency.
      </p>
      <img src="/career-track/design-system.png" alt="Design system" class="w-full" />
    </section>

    <!-- Key Learnings -->
    <section class="mb-12">
      <h2 class="font-semibold text-neutral-900 mb-5" style="font-size: 20px;">Impact</h2>
      <ol class="flex flex-col gap-5">
        <li class="flex gap-4">
          <span class="text-xs text-neutral-400 shrink-0 font-[Chillax,sans-serif] leading-7">01</span>
          <p class="text-neutral-700 text-sm leading-7">Career Track saved the company money by eliminating the need for external software applications such as Tableau, Excel, Solvedio, and others.</p>
        </li>
        <li class="flex gap-4">
          <span class="text-xs text-neutral-400 shrink-0 font-[Chillax,sans-serif] leading-7">02</span>
          <p class="text-neutral-700 text-sm leading-7">Career Track replaced fragmented, undocumented processes with a unified system, giving managers and trainers a single source of truth for tracking employee skill progression and assigning tasks based on demonstrated competencies.</p>
        </li>
        <li class="flex gap-4">
          <span class="text-xs text-neutral-400 shrink-0 font-[Chillax,sans-serif] leading-7">03</span>
          <p class="text-neutral-700 text-sm leading-7">Employees gained clear visibility into the skills required for career advancement, reducing ambiguity around role elevation and creating a more transparent path for growth within the organisation.</p>
        </li>
        <li class="flex gap-4">
          <span class="text-xs text-neutral-400 shrink-0 font-[Chillax,sans-serif] leading-7">04</span>
          <p class="text-neutral-700 text-sm leading-7">Career Track improved workforce quality across multiple company domains, including Manufacturing, Sales, Service, and Energy, by standardising how skills are defined, tracked, and developed at scale.</p>
        </li>
      </ol>
    </section>

  </main>
</Layout>

<style>
  .visit-btn:hover {
    background-color: #B1B6DF;
    color: #000;
    font-weight: 600;
  }
</style>
