---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Construct - Lina">

<main class="max-w-2xl mx-auto px-6 py-12">

    <!-- Back -->
    <a href="/" class="inline-flex items-center gap-2 text-sm text-neutral-700 hover:text-neutral-900 transition-colors mb-10">
      ← Back
    </a>

    <!-- Header -->
    <header class="mb-10">
      <div class="flex items-start justify-between gap-4 mb-2">
        <h1 class="font-semibold text-neutral-900" style="font-size: 32px;">Construct</h1>
      </div>
      <p class="text-neutral-700 leading-relaxed">
        Construction management application.
      </p>
    </header>

    <!-- Meta -->
    <dl class="flex flex-col gap-4 text-sm">
      <div>
        <dt class="text-xs text-neutral-500 mb-1">Role</dt>
        <dd class="text-neutral-900">UX/UI Designer</dd>
      </div>
      <div>
        <dt class="text-xs text-neutral-500 mb-1">Timeline</dt>
        <dd class="text-neutral-900">2023 — 2025</dd>
      </div>
      <div>
        <dt class="text-xs text-neutral-500 mb-1">Team</dt>
        <dd class="text-neutral-900">—</dd>
      </div>
    </dl>

    <div class="mt-10"></div>

    <!-- User Problems -->
    <section class="mb-10">
      <h2 class="font-semibold text-neutral-900 mb-4" style="font-size: 20px;">User Problems</h2>
      <div class="flex flex-col gap-5">
        <div>
          <p class="text-xs text-neutral-500 mb-1.5">User type</p>
          <p class="text-neutral-700 text-sm leading-7">User problem description.</p>
        </div>
      </div>
    </section>

    <!-- Product Background -->
    <section class="mb-10">
      <h2 class="font-semibold text-neutral-900 mb-3" style="font-size: 20px;">Product Background</h2>
      <p class="text-neutral-700 text-sm leading-7 mb-5">
        Product background description.
      </p>
      <img src="/Construct/Site Map - c.jpg" alt="Site map" class="w-full" />
    </section>

  </main>
</Layout>
