---
import Layout from '../layouts/Layout.astro';
import { projects } from '../data/projects';
import CyclingText from '../components/CyclingText.astro';

const productProjects = projects.filter(p => p.category === 'products');
const uxProjects = projects.filter(p => p.category === 'ux');
---

<Layout>
  <main class="max-w-5xl mx-auto px-6 py-14">

    <!-- Header with avatar -->
    <header class="mb-10 flex flex-col md:flex-row md:items-center gap-4 md:gap-6">
      <img
        src="/Pin Image.PNG"
        alt="Lina Charara"
        class="shrink-0 w-24 h-auto md:w-auto md:h-auto" style="max-width: 161px; max-height: 180px;"
      />
      <div>
        <h1 class="font-semibold text-neutral-900 mb-2 text-2xl md:text-[32px]">Lina Charara</h1>
        <p class="text-neutral-700 text-sm md:text-base">Product Designer at Tesla. <span class="hidden md:inline">Building products <CyclingText words={["that solve user problems.", "that are simple.", "that are easy to use.", "that are fun.", "that are unique."]} className="text-neutral-700 text-sm md:text-base font-semibold" /></span></p>
        <p class="text-neutral-700 text-sm mt-1 md:hidden">Building products <CyclingText words={["that solve user problems.", "that are simple.", "that are easy to use.", "that are fun.", "that are unique."]} className="text-neutral-700 text-sm font-semibold" /></p>
      </div>
    </header>

    <!-- Products I've Built -->
    <div class="relative mb-10">
      <img src="/Product I've Built.PNG" alt="Products I Have Built" class="w-48 md:w-64 mb-3" />
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {productProjects.map((project) => (
          <a
            href={`/projects/${project.slug}`}
            class="group relative block"
          >
            <img
              src={project.defaultImage ?? '/Skills Default.png'}
              alt={project.title}
              class="w-full group-hover:opacity-0 transition-opacity duration-200"
            />
            <img
              src={project.hoverImage ?? '/Skills Hover.png'}
              alt={project.title}
              class="w-full absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-200"
            />
            <div class="absolute bottom-0 left-0 w-full h-[40%] max-w-[75%] flex flex-col gap-1 md:gap-2 items-start justify-center pl-4 md:pl-6">
              <h3 class="text-sm font-semibold text-neutral-900">{project.title}</h3>
              <p class="text-[12px] md:text-[13px] text-neutral-700">{project.description}</p>
            </div>
          </a>
        ))}
      </div>

      <!-- Hire me Roach character - top right, hidden on mobile -->
      <a href="/about" class="absolute top-[-3.75rem] right-[-5.5rem] z-10 hidden md:block">
        <img
          src="/Hire me roach.PNG"
          alt="Hire me roach character"
          class="w-40 md:w-44"
        />
      </a>
    </div>

    <!-- UX Use Cases -->
    <div>
      <img src="/UX Use Cases.PNG" alt="UX Use Cases" class="w-40 md:w-56 mb-3" />
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {uxProjects.map((project) => (
          <a
            href={`/projects/${project.slug}`}
            class="group relative block"
          >
            <img
              src={project.defaultImage ?? '/Skills Default.png'}
              alt={project.title}
              class="w-full group-hover:opacity-0 transition-opacity duration-200"
            />
            <img
              src={project.hoverImage ?? '/Skills Hover.png'}
              alt={project.title}
              class="w-full absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-200"
            />
            <div class="absolute bottom-0 left-0 w-full h-[40%] max-w-[75%] flex flex-col gap-1 md:gap-2 items-start justify-center pl-4 md:pl-6">
              <h3 class="text-sm font-semibold text-neutral-900">{project.title}</h3>
              <p class="text-[12px] md:text-[13px] text-neutral-700">{project.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>

  </main>
</Layout>
