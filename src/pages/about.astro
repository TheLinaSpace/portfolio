---
import Layout from '../layouts/Layout.astro';

const links = [
  { label: 'GitHub',   href: 'https://github.com/TheLinaSpace'     },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/linacharara/?lipi=urn%3Ali%3Apage%3Ad_flagship3_profile_view_base_contact_details%3BbJafjencR%2Baif5PHNJVFiw%3D%3D' },
];
---

<Layout title="About - Lina">
  <main class="max-w-2xl mx-auto px-6 py-20">

    <header class="mb-12">
      <h1 class="text-2xl font-semibold text-neutral-900 mb-2">About</h1>
      <p class="text-neutral-700 text-sm">A little bit about me.</p>
    </header>

    <div class="text-neutral-700 text-sm leading-7 space-y-4 mb-16">
      <p>
        I am a product designer with 3 and a half years of experience. I am looking into new opportunities where I can take part in not just designing the products, but also contributing to building them.
      </p>
      <p>
        To get in touch: Send a message to <a href="mailto:Lina.m.charara@gmail.com" class="underline hover:text-neutral-900 transition-colors">Lina.m.charara@gmail.com</a>
      </p>
    </div>

    <h2 class="text-xs uppercase tracking-widest text-neutral-700 mb-4">Get in touch</h2>
    <ul class="flex flex-col gap-3">
      {links.map(({ label, href }) => (
        <li>
          <a
            href={href}
            target={href.startsWith('http') ? '_blank' : undefined}
            rel={href.startsWith('http') ? 'noopener noreferrer' : undefined}
            class="flex items-center justify-between border border-neutral-200 px-5 py-4 text-sm text-neutral-700 hover:border-neutral-400 hover:text-neutral-900 transition-all"
          >
            {label}
            <span class="text-neutral-700">↗</span>
          </a>
        </li>
      ))}
    </ul>

  </main>
</Layout>
