---
interface Props {
  prefix?: string;
  words: string[];
  className?: string;
}

const { prefix = '', words, className = '' } = Astro.props;
---

<span class={className} data-cycling-text data-words={JSON.stringify(words)}>
  {prefix}<span class="cycling-word" style="display: inline; transition: opacity 400ms ease, transform 400ms ease;">{words[0]}</span>
</span>

<script>
  document.querySelectorAll('[data-cycling-text]').forEach((el) => {
    const words: string[] = JSON.parse(el.getAttribute('data-words') || '[]');
    if (words.length <= 1) return;

    const wordEl = el.querySelector('.cycling-word') as HTMLElement;

    let index = 0;

    setInterval(() => {
      wordEl.style.opacity = '0';
      wordEl.style.transform = 'translateY(6px)';

      setTimeout(() => {
        index = (index + 1) % words.length;
        wordEl.textContent = words[index];

        wordEl.style.transform = 'translateY(-6px)';
        wordEl.style.transition = 'none';

        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            wordEl.style.transition = 'opacity 400ms ease, transform 400ms ease';
            wordEl.style.opacity = '1';
            wordEl.style.transform = 'translateY(0)';
          });
        });
      }, 400);
    }, 2000);
  });
</script>
